#: ../src/dialog_about.ui:14
msgid "About uChmViewer"
msgstr "О uChmViewer"

#: ../src/dialog_about.ui:24
msgid "About application"
msgstr "О приложении"

#: ../src/dialog_about.ui:46
msgid "About text"
msgstr "Текст о приложении"

#: ../src/dialog_about.ui:57
msgid "Thanks"
msgstr "Благодарности"

#: ../src/dialog_about.ui:63
msgid ""
"<!DOCTYPE HTML PUBLIC \"-//W3C//DTD HTML 4.0//EN\" \"http://www.w3.org/TR/"
"REC-html40/strict.dtd\">\n"
"<html><head><meta name=\"qrichtext\" content=\"1\" /></head>\n"
"<body>\n"
"<p>I would like to thank:</p>\n"
"<ul>\n"
"<li>George Yunaev, the author of KchmViewer.</li>\n"
"<li>Razvan Cojocaru, the author of xchm.</li>\n"
"<li>Peter Volkov for significant QA (more than 20 reported bugs!).</li>\n"
"<li>And of course <b>everyone</b>, who report bugs, and suggest features.</"
"li>\n"
"</ul>\n"
"</body></html>"
msgstr ""
"<!DOCTYPE HTML PUBLIC \"-//W3C//DTD HTML 4.0//EN\" \"http://www.w3.org/TR/"
"REC-html40/strict.dtd\">\n"
"<html><head><meta name=\"qrichtext\" content=\"1\" /></head>\n"
"<body>\n"
"<p>Я выражаю благодарность:</p>\n"
"<ul>\n"
"<li>George Yunaev, автору KchmViewer.</li>\n"
"<li>Razvan Cojocaru, автору xchm.</li>\n"
"<li>Peter Volkov за деятельное QA (более чем 20 найденых ошибок!)</li>\n"
"<li>И конечно же <b>всем</b>, кто сообщал об ошибках и предлагал улучшения.</"
"li>\n"
"</ul>\n"
"</body></html>"

#: ../src/dialog_about.ui:84
msgid "3rd party software"
msgstr "Стороннее ПО"

#: ../src/dialog_about.ui:90
msgid ""
"<!DOCTYPE HTML PUBLIC \"-//W3C//DTD HTML 4.0//EN\" \"http://www.w3.org/TR/"
"REC-html40/strict.dtd\">\n"
"<html><head><meta name=\"qrichtext\" content=\"1\" /></head>\n"
"<body>\n"
"<p>uChmViewer uses the following 3rd party software:</p>\n"
"<ul>\n"
"<li>Qt library from http://qt-project.org by Digia.</li>\n"
"<li>CHMLib for parsing CHM files by Jed Wing.</li>\n"
"<li>libzip for handling EPUB files by Dieter Baron and Thomas Klausner.</"
"li>\n"
"<li>Icons from DryIcons, <a href='https://dryicons.com'>https://dryicons."
"com</a>.</li>\n"
"</ul>\n"
"</body></html>"
msgstr ""
"<!DOCTYPE HTML PUBLIC \"-//W3C//DTD HTML 4.0//EN\" \"http://www.w3.org/TR/"
"REC-html40/strict.dtd\">\n"
"<html><head><meta name=\"qrichtext\" content=\"1\" /></head>\n"
"<body>\n"
"<p>uChmViewer использует следующее стороннее ПО:</p>\n"
"<ul>\n"
"<li>Библиотеки Qt от Digia, http://qt-project.org.</li>\n"
"<li>CHMLib от Jed Wing для разбора файлов CHM.</li>\n"
"<li>libzip от Dieter Baron и Thomas Klausner для распаковки файлов EPUB.</"
"li>\n"
"<li>Значки от DryIcons, <a href=\"https://dryicons.com\">https://dryicons."
"com</a>.</li>\n"
"</ul>\n"
"</body></html>"

